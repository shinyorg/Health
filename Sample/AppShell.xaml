<?xml version="1.0" encoding="UTF-8"?>
<shiny:ShinyShell x:Class="Sample.AppShell"
                  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:shiny="clr-namespace:Shiny;assembly=Shiny.Maui.Shell"
                  xmlns:local="clr-namespace:Sample"
                  Title="Shiny Health">

    <TabBar>
        <ShellContent Title="Dashboard"
                      ContentTemplate="{DataTemplate local:HealthTestPage}"
                      Route="HealthTest" />

        <ShellContent Title="Write Data"
                      ContentTemplate="{DataTemplate local:WritePage}"
                      Route="Write" />

        <ShellContent Title="Observe"
                      ContentTemplate="{DataTemplate local:ObservePage}"
                      Route="Observe" />
    </TabBar>

</shiny:ShinyShell>