<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sample="clr-namespace:Sample"
             xmlns:health="clr-namespace:Shiny.Health;assembly=Shiny.Health"
             x:DataType="sample:ListViewModel"
             x:Class="Sample.ListPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto, *" Padding="16" RowSpacing="16">

        <!-- Filter Card -->
        <Border StrokeShape="RoundRectangle 12"
                StrokeThickness="0"
                BackgroundColor="{StaticResource Surface}"
                Padding="16"
                Grid.Row="0">
            <Border.Shadow>
                <Shadow Brush="{StaticResource Gray300Brush}" Offset="0,2" Radius="8" Opacity="0.3" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="12">
                <Label Text="Time Range"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <Grid RowDefinitions="Auto, Auto"
                      ColumnDefinitions="Auto, *, *"
                      ColumnSpacing="8"
                      RowSpacing="8">

                    <Label Text="From"
                           VerticalOptions="Center"
                           TextColor="{StaticResource TextSecondary}"
                           Grid.Row="0" Grid.Column="0" />
                    <DatePicker Date="{Binding DateStart}"
                                TextColor="{StaticResource TextPrimary}"
                                Grid.Row="0" Grid.Column="1" />
                    <TimePicker Time="{Binding TimeStart}"
                                TextColor="{StaticResource TextPrimary}"
                                Grid.Row="0" Grid.Column="2" />

                    <Label Text="To"
                           VerticalOptions="Center"
                           TextColor="{StaticResource TextSecondary}"
                           Grid.Row="1" Grid.Column="0" />
                    <DatePicker Date="{Binding DateEnd}"
                                TextColor="{StaticResource TextPrimary}"
                                Grid.Row="1" Grid.Column="1" />
                    <TimePicker Time="{Binding TimeEnd}"
                                TextColor="{StaticResource TextPrimary}"
                                Grid.Row="1" Grid.Column="2" />
                </Grid>

                <Button Text="Run Query"
                        Command="{Binding LoadCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="44" />
            </VerticalStackLayout>
        </Border>

        <!-- Results List -->
        <CollectionView ItemsSource="{Binding Data}"
                        Grid.Row="1">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Padding="40">
                    <Label Text="No Data"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Label Text="Select a time range and run a query"
                           FontSize="14"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="health:NumericHealthResult">
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Surface}"
                            Padding="14"
                            Margin="0,0,0,8">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource Gray300Brush}" Offset="0,1" Radius="4" Opacity="0.15" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Spacing="2" Grid.Column="0">
                                <Label FontSize="12"
                                       TextColor="{StaticResource TextMuted}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Start, StringFormat='{0:MMM dd, h:mm tt}'}" />
                                            <Span Text=" - " />
                                            <Span Text="{Binding End, StringFormat='{0:h:mm tt}'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                            <Label Text="{Binding Value, StringFormat='{0:N1}'}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"
                                   Grid.Column="1" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
